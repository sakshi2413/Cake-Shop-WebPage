pipeline {
  agent any
  stages {
    stage('') {
      steps {
        bat 'echo"compiling"'
      }
    }

    stage('Test') {
      steps {
        bat 'echo Running Tests'
      }
    }

    stage('Deploy') {
      steps {
        bat 'echo Deploying application'
      }
    }

    stage('End') {
      steps {
        bat 'echo Pipeline completed'
      }
    }

  }
}